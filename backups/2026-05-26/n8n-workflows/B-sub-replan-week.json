    {
      "parameters": {
        "jsCode": "const trigger    = $('Execute Workflow Trigger').first().json;\nconst reason     = trigger.reason || 'athlete requested replan';\nconst athleteRaw = $('Read Athlete Profile').first().json;\nconst athlete    = athleteRaw.fields ?? athleteRaw;\nconst planItems  = $('Read Existing Week Plan').all();\nconst stravaAll  = $('Read Recent Strava').all();\n\nconst isoDate = d => d.toISOString().slice(0,10);\nconst today   = new Date();\ntoday.setHours(0,0,0,0);\n\n// Compute phase from target date\nconst rawDate    = athlete.hyrox_target_date || '2026-07-18';\nconst targetDate = new Date(rawDate);\nconst daysToRace = Math.floor((targetDate - today) / (1000*60*60*24));\nconst weeksToRace = Math.ceil(daysToRace / 7);\nlet phase;\nif (weeksToRace <= 2) phase = 'Taper';\nelse if (weeksToRace <= 5) phase = 'Peak';\nelse if (weeksToRace <= 12) phase = 'Build';\nelse phase = 'Base';\nconst totalPrepWeeks = 20;\nconst weekNumber = Math.max(1, totalPrepWeeks - weeksToRace + 1);\n\n// Plan the full Mon-Sun of the target week.\n// If today is Mon or Tue, plan THIS week. Otherwise plan NEXT week.\nconst dayOfWeek = today.getDay(); // 0=Sun, 1=Mon...6=Sat\nconst isEarlyThisWeek = dayOfWeek >= 1 && dayOfWeek <= 2;\nconst daysToMonday = isEarlyThisWeek\n  ? (1 - dayOfWeek)                          // Mon=0, Tue=-1 (back to Mon)\n  : (dayOfWeek === 0 ? 1 : 8 - dayOfWeek);  // next Monday\n\nconst weekStartObj = new Date(today);\nweekStartObj.setDate(today.getDate() + daysToMonday);\n\nconst remaining_dates = Array.from({ length: 7 }, (_, i) => {\n  const d = new Date(weekStartObj);\n  d.setDate(weekStartObj.getDate() + i);\n  return isoDate(d);\n});\n\nconst weekStart = remaining_dates[0];\nconst weekEnd   = remaining_dates[6];\n\n// Sessions that are done/skipped — we do NOT delete these\nconst doneIds    = planItems\n  .filter(i => { const f = i.json.fields ?? i.json; return f.status === 'done' || f.status === 'skipped'; })\n  .map(i => i.json.id)\n  .filter(Boolean);\n\n// Sessions that are planned and fall on remaining dates — candidates for deletion\nconst plannedIds = planItems\n  .filter(i => {\n    const f = i.json.fields ?? i.json;\n    const d = f.date || '';\n    return f.status === 'planned' && remaining_dates.includes(d.substring(0,10));\n  })\n  .map(i => i.json.id)\n  .filter(Boolean);\n\n// Completed sessions summary (for context)\nconst doneSummary = planItems\n  .filter(i => { const f = i.json.fields ?? i.json; return f.status === 'done' || f.status === 'skipped'; })\n  .map(i => { const f = i.json.fields ?? i.json; return '- ' + (f.date||'?') + ': ' + (f.session_type||'?') + ' (' + (f.status||'?') + ')'; })\n  .join('\\n') || 'None so far this week';\n\nconst recentActivity = stravaAll.length === 0\n  ? 'No recent Strava activities'\n  : stravaAll.map(a => '- ' + (a.json.name||'Activity') + ' (' + (a.json.type||'?') + ', ' + Math.round((a.json.distance||0)/100)/10 + 'km, ' + Math.round((a.json.moving_time||0)/60) + 'min, ' + (a.json.start_date_local||'').substring(0,10) + ')').join('\\n');\n\nreturn [{\n  json: {\n    reason, phase, weeks_to_race: weeksToRace, week_number: weekNumber,\n    week_start: weekStart, week_end: weekEnd,\n    remaining_dates, planned_ids_to_delete: plannedIds,\n    done_sessions_summary: doneSummary, recent_strava: recentActivity,\n    athlete_name: athlete.name || 'Athlete',\n    equipment_home: Array.isArray(athlete.equipment_home) ? athlete.equipment_home.join(', ') : (athlete.equipment_home || '')\n  }\n}];"
      },
