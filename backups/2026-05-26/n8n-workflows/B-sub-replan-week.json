    {
      "parameters": {
        "promptType": "define",
        "text": "={{ 'Athlete: ' + $json.athlete_name + '\\nPhase: ' + $json.phase + ' (Week ' + $json.week_number + ', ' + $json.weeks_to_race + ' weeks to race)' + '\\nReason for replan: ' + $json.reason + '\\nEquipment at home: ' + $json.equipment_home + '\\n\\nRemaining dates to plan (today onwards): ' + JSON.stringify($json.remaining_dates) + '\\n\\nSessions completed this week (DO NOT re-plan these):\\n' + $json.done_sessions_summary + '\\n\\nRecent training:\\n' + $json.recent_strava + '\\n\\nCalendar events (for travel day detection):\\n' + $json.calendar_context + '\\n\\nReplan ONLY the remaining_dates listed above. Produce sessions array + recap.' }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are Hyrox Coach. The athlete has requested a mid-week replan. You receive the remaining unstarted sessions of the current week and must replace them with a better-suited plan given the reason provided, recent fatigue, and any calendar constraints.\n\nRules:\n- Only plan sessions for the dates provided in remaining_dates. Do not plan past dates or future weeks.\n- Respect the athlete's current phase and training load from recent_strava.\n- On travel days (calendar events with non-local locations or travel-related titles): use Active recovery or Z2 endurance, cap at 45min, intensity easy, note \"Travel day\".\n- Provide a 2-3 sentence recap explaining the changes.\n- Use hyrox_knowledge_base to ground recommendations.\n- CHEAT MEAL: Preserve the cheat meal day from the original plan if it hasn't passed yet (default: Saturday). If replanning a cheat meal day, reassign it to Saturday or the nearest social event in the calendar. On cheat meal day: dinner is 'Dinner: Cheat meal -- enjoy freely', add 400-600 kcal above baseline, keep all other slots disciplined, notes: 'Cheat meal day (dinner) -- planned indulgence. Back on track tomorrow morning.'"
        }
      },
