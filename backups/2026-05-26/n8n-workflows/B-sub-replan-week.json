    {
      "parameters": {
        "jsCode": "const rawItems = $input.all();\nconst calItems = rawItems.filter(i => i.json && i.json.summary);\nconst ctx = $('Compute Replan Window').first().json;\n\nconst calContext = calItems.length === 0\n  ? 'No calendar events in remaining days.'\n  : calItems.map(e => {\n      const startDate = (e.json.start && e.json.start.dateTime)\n        ? e.json.start.dateTime.substring(0,10)\n        : ((e.json.start && e.json.start.date) ? e.json.start.date : '?');\n      const loc = e.json.location ? ' [Location: ' + e.json.location + ']' : '';\n      return startDate + ': ' + (e.json.summary || 'Untitled') + loc;\n    }).join('\\n');\n\nreturn [{\n  json: {\n    ...ctx,\n    calendar_context: calContext\n  }\n}];"
      },
      "id": "e449ba2c-a836-4086-bf81-19a77874608c",
