      "id": "5d0e4156-6423-4a78-97e7-03df7bc0e995",
      "name": "Read Week Training Plan",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.2,
      "position": [
        400,
        0
      ],
      "retryOnFail": true,
