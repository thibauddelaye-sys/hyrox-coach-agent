    {
      "parameters": {
        "jsCode": "const items = $('Read Week Training Plan').all();\nif (items.length === 0) {\n  return [{ json: { week_plan: [], today_session: null } }];\n}\n\nconst todayIso = new Date().toISOString().slice(0, 10);\nconst weekPlan = items\n  .map(i => i.json.fields ?? i.json)\n  .filter(f => f && typeof f.date === 'string');\nconst today = weekPlan.find(d => d.date === todayIso) ?? null;\n\nreturn [{ json: { week_plan: weekPlan, today_session: today } }];"
      },
      "id": "47d8bf1b-ee69-494c-8ce7-44c59c273ca6",
      "name": "Coalesce Training Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        0
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ctx-001",
              "name": "athlete_name",
              "value": "={{ $('Read Athlete Profile').first().json.fields.name }}",
              "type": "string"
            },
            {
              "id": "ctx-002",
              "name": "phase",
              "value": "={{ ($json.today_session && $json.today_session.phase) || ($json.week_plan[0] && $json.week_plan[0].phase) || 'Build' }}",
              "type": "string"
            },
            {
              "id": "ctx-003",
              "name": "today_session_description",
              "value": "={{ ($json.today_session && $json.today_session.description) || 'No session planned for today' }}",
              "type": "string"
            },
            {
              "id": "ctx-004",
              "name": "today_session_duration",
              "value": "={{ $json.today_session && $json.today_session.duration_min !== null && $json.today_session.duration_min !== undefined ? String($json.today_session.duration_min) : '' }}",
              "type": "string"
            },
            {
              "id": "ctx-005",
              "name": "today_session_intensity",
              "value": "={{ ($json.today_session && $json.today_session.intensity) || '' }}",
              "type": "string"
            },
            {
              "id": "ctx-006",
              "name": "today_date",
              "value": "={{ $now.toFormat('yyyy-MM-dd') }}",
              "type": "string"
            },
            {
              "id": "ctx-007",
              "name": "week_overview",
              "value": "={{ $json.week_plan.length === 0 ? 'No sessions planned in the next 7 days' : $json.week_plan.map(d => '- ' + d.date + ': ' + (d.session_type || 'unspecified') + ' (' + (d.duration_min || '?') + ' min, ' + (d.intensity || '?') + ') — ' + (d.description || 'no description').substring(0, 80)).join('\\n') }}",
              "type": "string"
            },
            {
              "id": "6f17f8a4-57bf-44cc-a511-8290c2e014ec",
              "name": "=calendarcontext",
              "value": "=={{ $('Read Calendar').all().length === 0 ? 'No events scheduled today' : $('Read Calendar').all().map(e => '- ' + (e.json.summary || 'Untitled') + ' (' + (e.json.start?.dateTime?.substring(11,16) || 'all day') + ')').join('\\n') }}",
              "type": "string"
            },
            {
              "id": "7561195a-7908-420c-95eb-be1c0b85aadd",
              "name": "=stravacontext",
              "value": "=={{ $('Read recent activities').all().length === 0 ? 'No recent activities' : $('Read recent activities').all().map(a => '- ' + a.json.name + ' (' + a.json.type + ', ' + Math.round(a.json.distance / 100) / 10 + ' km, ' + Math.round(a.json.moving_time / 60) + ' min)').join('\\n') }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "4edff25b-804f-49a8-86c5-d72e9f206b77",
      "name": "Package Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1184,
        0
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ 'Athlete: ' + $json.athlete_name + '\\nPhase: ' + $json.phase + '\\nDate: ' + $json.today_date + '\\nToday session: ' + $json.today_session_description + ($json.today_session_duration ? '\\nDuration: ' + $json.today_session_duration + ' min' : '') + ($json.today_session_intensity ? '\\nIntensity: ' + $json.today_session_intensity : '') + '\\n\\nThis week ahead:\\n' + $json.week_overview + '\\n\\nToday calendar:\\n' + $json.calendarcontext + '\\n\\nRecent training (last activities, oldest to newest):\\n' + $json.stravacontext + '\\n\\nGenerate a 4-section daily brief in markdown.\\n\\nCRITICAL RULES — these are non-negotiable:\\n1. The Workout section MUST reference the calendar above (mention specific event by name if relevant).\\n2. The Workout section SHOULD reference at least one upcoming session from the week ahead (e.g. how todays session prepares for tomorrows long run).\\n3. The Recovery section MUST reference the recent training above (e.g. after the 11km hike, prioritize sleep).\\n4. You MUST use the hyrox_knowledge_base tool at least once for nutrition recommendations.\\n\\n\\u{1F3CB}\\uFE0F *Workout*\\nDescribe the session concretely: what to do, equipment, intent, coaching cues. Start with a timing recommendation based on the calendar. Mention how it fits in the weekly plan.\\n\\n\\u{1F957} *Nutrition*\\n3-4 specific meal suggestions with rough kcal and macro targets, timed around the session. Cite evidence from the knowledge base.\\n\\n\\u{1F4A4} *Recovery and notes*\\n3 bullets MANDATORY:\\n- Hydration target (with numbers)\\n- Sleep target (with numbers)\\n- One specific insight referencing a named activity from the recent training above\\n\\n\\u{1F4DA} *Sources*\\nList the knowledge base sources you used.' }}",
        "options": {
          "systemMessage": "You are Hyrox Coach, an AI agent providing personalised training and nutrition coaching to a single athlete preparing for Hyrox races. You combine the role of a strength & conditioning coach, an endurance coach, and a sports nutritionist. In the Briefing role (active now), you produce a structured daily brief. Be specific and numbers-backed — the athlete had months of generic advice; contextual precision is your value. Total response: 200-350 words. Use markdown for structure. Sources: Include this section only if retrieved knowledge base sources were actually used. List 1-3 short bullet points with the source title, document name, or category.\nAlways use hyrox_knowledge_base before writing the brief when the answer may require Hyrox knowledge, nutrition guidance, recovery recommendations, or athlete-specific background not already present in Package Context. Do not invent unsupported facts."
        }
      },
