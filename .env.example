# Hyrox Coach Agent — environment variables
# Copy this file to .env and fill in your secrets. Never commit .env.

# ─── OpenAI (primary LLM provider) ────────────────────────────────────
# This project uses OpenAI for all LLM calls (briefing, chat, vision, 
# embeddings). You can switch between two keys:
#  - Personal key: visible on platform.openai.com/usage, good for dev
#  - Bootcamp key: limited credits, reserved for stable production runs
# Pick one as the active key, keep the other as a documented fallback.
OPENAI_API_KEY=sk-...
# Optional: a separate key only used by rag-ingestion/ingest.py to keep 
# embedding costs auditable. If unset, falls back to OPENAI_API_KEY.
OPENAI_EMBEDDING_API_KEY=

# Model names (centralised here so workflows reference env vars, not 
# hardcoded model strings — easier to tune cost vs quality later)
OPENAI_MODEL_BRIEFING=gpt-5.4
OPENAI_MODEL_CHAT=gpt-5.4-mini
OPENAI_MODEL_VISION=gpt-5.4-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# ─── Anthropic (optional — only for local Claude Code dev sessions) ──
# Not used by any workflow. Claude Code in VS Code authenticates via 
# the Pro subscription, not via this key. Leave empty if you don't have 
# Anthropic API credits.
# ANTHROPIC_API_KEY=

# ─── Airtable ──────────────────────────────────────────────────────────
# Personal Access Token scoped to the "Hyrox Coach" base only.
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# ─── Pinecone ──────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=hyrox-knowledge-base
PINECONE_ENVIRONMENT=us-east-1-aws

# ─── Cohere (re-ranking) ──────────────────────────────────────────────
COHERE_API_KEY=...

# ─── Telegram ──────────────────────────────────────────────────────────
# The bot token from BotFather (same bot you used in the Lead Capture lab 
# can be reused, or create a dedicated one).
TELEGRAM_BOT_TOKEN=...
# Chat ID for the athlete's main conversation with the bot.
TELEGRAM_ATHLETE_CHAT_ID=...
# Chat ID for system/error notifications (create a separate private 
# channel and add the bot to it).
TELEGRAM_SYSTEM_CHAT_ID=...

# ─── Strava ────────────────────────────────────────────────────────────
# Create an app at developers.strava.com to get client_id and client_secret.
# The refresh_token is generated once via the OAuth dance — see 
# rag-ingestion/strava-bootstrap.py.
STRAVA_CLIENT_ID=...
STRAVA_CLIENT_SECRET=...
STRAVA_REFRESH_TOKEN=...

# ─── Google Calendar ──────────────────────────────────────────────────
# Configured inside n8n via OAuth; no env vars needed for the workflow 
# itself. Listed here only if dashboard/app.py grows a calendar feature.

# ─── n8n (used only by Python scripts that might call n8n webhooks) ──
N8N_BASE_URL=https://thiba-d.n8n.irn.hk
